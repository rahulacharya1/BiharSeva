# ──────────────────────────────────────────────────────────────
# BiharSeva — Environment Configuration Template
# Copy this file to .env and fill in the values.
# NEVER commit .env with real credentials to version control.
# ──────────────────────────────────────────────────────────────

# ─── Django Core ─────────────────────────────────────────────
# Generate a new key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE-ME-to-a-random-50-char-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ─── Security (set to True in production) ────────────────────
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# ─── Email (SMTP) ───────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=BiharSeva <your-email@gmail.com>
CONTACT_RECIPIENT_EMAIL=contact@yourdomain.com
EVENT_ANNOUNCEMENT_VERIFIED_ONLY=False

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ─── Frontend & CORS ────────────────────────────────────────
# FRONTEND_URL=http://localhost:5173
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
